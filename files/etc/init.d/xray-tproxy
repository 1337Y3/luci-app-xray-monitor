#!/bin/sh /etc/rc.common
# Watchdog service for the managed-xray tproxy firewall (luci-app-xray-monitor).
# The watch loop syncs `table ip xray_tproxy` to reality every 5s: rules are
# only up while xray-monitor.fw.enabled=1 AND xray listens on the tproxy port,
# and a ~30s end-to-end probe tears them down if xray wedges while listening.
# `stop` is a full teardown, so "/etc/init.d/xray-tproxy stop" is a kill switch
# too (the persistent one is "/usr/share/xray-monitor/xray-fw off").

START=99
STOP=89
USE_PROCD=1

FW=/usr/share/xray-monitor/xray-fw

start_service() {
	procd_open_instance
	procd_set_param command "$FW" watch
	procd_set_param respawn 3600 5 0
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	"$FW" down
}
