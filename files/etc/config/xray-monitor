# Global settings. Subscriptions are separate 'subscription' sections
# (added from the UI), each with: prefix, url, enabled.
config xray-monitor 'sub'
	option user_agent 'v2rayNG/1.8.0'
	# scheduled fetch: enable + cron expression
	option cron '1'
	option cron_schedule '0 * * * *'
	# auto-apply (splice + restart xray) when a scheduled/manual fetch finds changes
	option auto_apply '0'
	# auto-enable the Xray Stats API in config.json on package install (1=yes)
	option auto_enable_api '1'

# Transparent-proxy firewall (nft tproxy of all LAN TCP into xray).
# enabled=0 keeps everything down; the migration script turns it on.
config fw 'fw'
	option enabled '0'
	option tproxy_port '1200'
	option probe_port '1201'
	# 0x100: sockopt.mark on xray outbounds (nft loop guard skips it)
	option mark_out '256'
	# 0x200: fwmark/ctmark for tproxy policy routing (masked ops, zapret-safe)
	option mark_tproxy '512'
	option rt_table '100'
	option lan_if 'br-lan'
	# QUIC/HTTP3 tproxy (opt-in): when 1, ALSO tproxy LAN UDP on udp_ports
	# (default 443) into xray so listed domains' QUIC tunnels too. Ships OFF;
	# other UDP (DNS/voice/games) is never touched - zapret keeps owning it.
	option tproxy_udp '0'
	option udp_ports '443'
	# Resolve at exit (opt-in): when 1, the sniffed SNI OVERRIDES the dst so
	# proxy exits resolve the domain at the VPS (remote DNS - immune to client
	# poisoning + exit-correct CDN geo); direct exits re-resolve via router DoH.
	# Ships OFF; caveat: can misroute ECH/domain-fronting/IP-pinned connections.
	option resolve_exit '0'

# Managed xray routing (lists/devices/georules -> routing.rules).
# managed=0 = master gate: genrules/xray-rules refuse to touch config.json.
config routing 'rules'
	option managed '0'
	option default_exit 'direct'
	# RKN-registry replacement: geosite/geoip rules -> registry_exit.
	# Ships disabled; opt-in via 'migrate-ruantiblock enable-registry' (downloads geodata).
	option registry_enabled '0'
	option registry_exit 'balancer-default'
	option registry_geosite 'ru-blocked'
	option registry_geoip 'ru-blocked'

# geoip.dat/geosite.dat auto-update (runetfreedom by default).
# cron ships OFF: an update restarts xray, so nothing is scheduled until the
# feature is actually in use ('enable-registry' arms it, or toggle it on the
# Geodata page). Geodata is only meaningful once geosite/geoip rules exist.
config geodat 'geodat'
	option enabled '1'
	option cron '0'
	# Mon+Thu 05:00 — every real update restarts xray, daily would be churn
	option cron_schedule '0 5 * * 1,4'
	option source_url 'https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release'
