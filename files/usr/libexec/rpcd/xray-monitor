#!/bin/sh
# rpcd backend for luci-app-xray-monitor
# ubus object: xray-monitor   methods: status, stats, outbounds
. /usr/share/libubox/jshn.sh

XRAY="/usr/bin/xray"
API_SERVER="127.0.0.1:10085"

# Resolve the active xray config file (for endpoint discovery)
config_file() {
	local f
	f=$(uci -q get xray.config.conffiles 2>/dev/null | awk '{print $1}')
	[ -f "$f" ] && { echo "$f"; return; }
	echo "/etc/xray/config.json"
}

# Detect the config double-load footgun: xray launched with -confdir D *and*
# -config F where F lives inside D, so D/*.json loads F a second time. Harmless
# until it isn't (inbounds, incl. the api on 10085, can fail to bind).
confdir_dup() {
	local pid="$1" tok prev confdirs="" configs="" d f
	[ -n "$pid" ] && [ -r "/proc/$pid/cmdline" ] || return 1
	prev=""
	while IFS= read -r tok; do
		case "$prev" in
			-confdir|--confdir) confdirs="$confdirs $tok" ;;
			-config|--config)   configs="$configs $tok" ;;
		esac
		case "$tok" in
			-confdir=*|--confdir=*) confdirs="$confdirs ${tok#*=}" ;;
			-config=*|--config=*)   configs="$configs ${tok#*=}" ;;
		esac
		prev="$tok"
	done <<EOF
$(tr '\0' '\n' < "/proc/$pid/cmdline" 2>/dev/null)
EOF
	[ -n "$confdirs" ] && [ -n "$configs" ] || return 1
	for f in $configs; do
		for d in $confdirs; do
			[ "$(dirname "$f")" = "${d%/}" ] && return 0
		done
	done
	return 1
}

get_status() {
	local pid hz starttime sysuptime up=0 running=0 version
	pid=$(pgrep -f "$XRAY run" | head -n1)
	version=$($XRAY version 2>/dev/null | head -n1)
	if [ -n "$pid" ] && [ -d "/proc/$pid" ]; then
		running=1
		hz=$(getconf CLK_TCK 2>/dev/null)
		[ -n "$hz" ] || hz=100
		starttime=$(awk '{print $22}' "/proc/$pid/stat" 2>/dev/null)
		sysuptime=$(awk '{print int($1)}' /proc/uptime 2>/dev/null)
		if [ -n "$starttime" ] && [ -n "$sysuptime" ]; then
			up=$(( sysuptime - starttime / hz ))
			[ "$up" -lt 0 ] && up=0
		fi
	fi
	json_init
	json_add_boolean running "$running"
	json_add_int pid "${pid:-0}"
	json_add_int uptime "$up"
	json_add_string version "${version:-unknown}"
	json_add_string app_version "$(opkg status luci-app-xray-monitor 2>/dev/null | sed -n 's/^Version: //p' | head -n1)"
	json_add_boolean confdir_dup "$(confdir_dup "$pid" && echo 1 || echo 0)"
	json_dump
}

get_stats() {
	local out
	out=$($XRAY api statsquery --server="$API_SERVER" 2>/dev/null)
	case "$out" in
		\{*) printf '%s' "$out" ;;
		*)   printf '{"stat":[]}' ;;
	esac
}

# TCP-reachability probe -> echoes "<up> <ms>"  (up: 1 reachable, 0 down, -1 no tool)
probe() {
	local a="$1" p="$2" t
	if command -v curl >/dev/null 2>&1; then
		t=$(curl -sk -o /dev/null --connect-timeout 3 --max-time 4 -w '%{time_connect}' "https://$a:$p" 2>/dev/null)
		case "$t" in
			""|0|0.0|0.000|0.000000) echo "0 0" ;;
			*) echo "1 $(awk "BEGIN{printf \"%d\", $t*1000}")" ;;
		esac
	elif command -v ncat >/dev/null 2>&1; then
		if ncat -z -w 3 "$a" "$p" >/dev/null 2>&1; then echo "1 0"; else echo "0 0"; fi
	else
		echo "-1 0"
	fi
}

# Is there a live (ESTABLISHED) connection to addr:port right now?
# Resolves hostnames to IPs (subscription servers use hostnames).
is_active() {
	local addr="$1" port="$2" ips ip
	case "$addr" in
		*[!0-9.]*) ips=$(resolveip -4 -t 2 "$addr" 2>/dev/null) ;;  # contains non-IPv4 chars => hostname
		*)         ips="$addr" ;;
	esac
	[ -n "$ips" ] || ips="$addr"
	for ip in $ips; do
		grep "ESTABLISHED" /proc/net/nf_conntrack 2>/dev/null \
			| grep "dst=$ip " | grep -q "dport=$port " && return 0
	done
	return 1
}

# Tags the user has turned off from the active TCP probe ("ping check"), so a
# blown/blocked endpoint isn't poked (its handshake can trigger an ISP reset).
# Stored as a UCI list; matched with surrounding spaces so substrings don't hit.
probe_disabled_list() {
	printf ' %s ' "$(uci -q get xray-monitor.sub.probe_disabled 2>/dev/null)"
}

get_outbounds() {
	local cfg n i tag addr port up ms active dis dlist tmp f
	cfg=$(config_file)
	dlist=$(probe_disabled_list)
	n=$(jsonfilter -i "$cfg" -e '@.outbounds[*].tag' 2>/dev/null | wc -l)
	tmp=$(mktemp -d)
	i=0
	while [ "$i" -lt "$n" ]; do
		tag=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].tag" 2>/dev/null)
		addr=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.vnext[0].address" 2>/dev/null)
		port=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.vnext[0].port" 2>/dev/null)
		[ -n "$addr" ] || addr=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.servers[0].address" 2>/dev/null)
		[ -n "$port" ] || port=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.servers[0].port" 2>/dev/null)
		case "$dlist" in *" $tag "*) dis=1 ;; *) dis=0 ;; esac
		if [ -n "$addr" ] && [ -n "$port" ]; then
			(
				if [ "$dis" = 1 ]; then
					up=-2; ms=0   # -2 = probe disabled by user
				else
					set -- $(probe "$addr" "$port"); up="$1"; ms="$2"
				fi
				# is_active only reads /proc/net/nf_conntrack (passive), so it's
				# safe to keep even for a disabled endpoint — no packet is sent.
				active=0; is_active "$addr" "$port" && active=1
				printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$tag" "$addr" "$port" "$up" "$ms" "$active" "$dis" \
					> "$tmp/$(printf '%03d' "$i")"
			) &
		fi
		i=$((i + 1))
	done
	wait

	json_init
	json_add_array "outbounds"
	for f in "$tmp"/*; do
		[ -f "$f" ] || continue
		IFS='	' read -r tag addr port up ms active dis < "$f"
		json_add_object
		json_add_string tag "$tag"
		json_add_string addr "$addr"
		json_add_int port "$port"
		json_add_int up "$up"
		json_add_int ms "$ms"
		json_add_boolean active "$active"
		json_add_boolean disabled "$dis"
		json_close_object
	done
	json_close_array
	json_dump
	rm -rf "$tmp"
}

# Turn the active probe on/off for one outbound tag. Idempotent + dedupes.
do_probe_set() {
	local input tag dis cur t
	input=$(cat)
	tag=$(echo "$input" | jsonfilter -e '@.tag' 2>/dev/null)
	dis=$(echo "$input" | jsonfilter -e '@.disabled' 2>/dev/null)
	if [ -z "$tag" ]; then
		json_init; json_add_boolean ok 0; json_add_string msg "missing tag"; json_dump; return
	fi
	uci -q get xray-monitor.sub >/dev/null 2>&1 || uci set xray-monitor.sub=xray-monitor
	cur=$(uci -q get xray-monitor.sub.probe_disabled 2>/dev/null)
	uci -q delete xray-monitor.sub.probe_disabled 2>/dev/null
	for t in $cur; do
		[ "$t" = "$tag" ] && continue
		uci add_list xray-monitor.sub.probe_disabled="$t"
	done
	[ "$dis" = 1 ] && uci add_list xray-monitor.sub.probe_disabled="$tag"
	uci commit xray-monitor
	json_init; json_add_boolean ok 1; json_dump
}

# Cheap metadata for the UI's first paint and for toggling without probing:
# every probeable outbound tag + whether it's disabled. No network probe, so it
# returns instantly (the slow per-exit connectivity comes from `outbounds`).
get_outmeta() {
	local cfg n i tag addr port dis dlist
	cfg=$(config_file)
	dlist=$(probe_disabled_list)
	n=$(jsonfilter -i "$cfg" -e '@.outbounds[*].tag' 2>/dev/null | wc -l)
	json_init
	json_add_array "outbounds"
	i=0
	while [ "$i" -lt "$n" ]; do
		tag=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].tag" 2>/dev/null)
		addr=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.vnext[0].address" 2>/dev/null)
		port=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.vnext[0].port" 2>/dev/null)
		[ -n "$addr" ] || addr=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.servers[0].address" 2>/dev/null)
		[ -n "$port" ] || port=$(jsonfilter -i "$cfg" -e "@.outbounds[$i].settings.servers[0].port" 2>/dev/null)
		if [ -n "$addr" ] && [ -n "$port" ]; then
			case "$dlist" in *" $tag "*) dis=1 ;; *) dis=0 ;; esac
			json_add_object
			json_add_string tag "$tag"
			json_add_boolean disabled "$dis"
			json_close_object
		fi
		i=$((i + 1))
	done
	json_close_array
	json_dump
}

# Reset all traffic counters to zero (reads+resets via the Stats API)
do_reset() {
	local rc
	$XRAY api statsquery --server="$API_SERVER" -reset >/dev/null 2>&1
	rc=$?
	json_init
	json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
	json_dump
}

SUB=/usr/share/xray-monitor/xray-sub
RULES=/usr/share/xray-monitor/xray-rules
FW=/usr/share/xray-monitor/xray-fw
GEODAT=/usr/share/xray-monitor/xray-geodat
STATE=/etc/xray-monitor

run_ok() {  # run a command, emit {"ok":bool}
	"$@" >/dev/null 2>&1
	local rc=$?
	json_init
	json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
	json_dump
}

# Validate the live xray config with `xray -test` (read-only)
do_validate() {
	local cfg out rc msg
	cfg=$(config_file)
	out=$($XRAY -test -format json -config "$cfg" 2>&1); rc=$?
	msg=$(printf '%s\n' "$out" | grep -viE '^Xray [0-9]|Penetrates Everything|unified platform|infra/conf/serial: Reading' | tr -s '\r\n\t ' ' ')
	json_init
	json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
	json_add_string config "$cfg"
	json_add_string msg "${msg:-no output}"
	json_dump
}

case "$1" in
	list)
		json_init
		json_add_object "status";     json_close_object
		json_add_object "stats";      json_close_object
		json_add_object "outbounds";  json_close_object
		json_add_object "out_meta";   json_close_object
		json_add_object "probe_set"; json_add_string "tag" ""; json_add_string "disabled" ""; json_close_object
		json_add_object "reset";      json_close_object
		json_add_object "sub_get";    json_close_object
		json_add_object "sub_fetch";  json_close_object
		json_add_object "sub_apply";  json_close_object
		json_add_object "sub_setcfg"
			json_add_string "cron" ""; json_add_string "cron_schedule" ""
			json_add_string "auto_apply" ""; json_add_string "user_agent" ""
		json_close_object
		json_add_object "sub_add"; json_add_string "prefix" ""; json_add_string "url" ""; json_close_object
		json_add_object "sub_del"; json_add_string "id" ""; json_close_object
		json_add_object "sub_edit"
			json_add_string "id" ""; json_add_string "prefix" ""
			json_add_string "url" ""; json_add_string "enabled" ""
		json_close_object
		json_add_object "rules_get"; json_close_object
		json_add_object "list_entries"; json_add_string "name" ""; json_close_object
		json_add_object "lists_set"; json_add_array "lists"; json_close_array; json_close_object
		json_add_object "devices_set"; json_add_array "devices"; json_close_array; json_close_object
		json_add_object "georules_set"; json_add_array "rules"; json_close_array; json_close_object
		json_add_object "routing_set"
			json_add_string "default_exit" ""; json_add_string "registry_enabled" ""
			json_add_string "registry_exit" ""; json_add_string "registry_geosite" ""
			json_add_string "registry_geoip" ""; json_add_string "tproxy_port" ""
		json_close_object
		json_add_object "rules_apply"; json_close_object
		json_add_object "fw_get"; json_close_object
		json_add_object "fw_set"; json_add_string "enabled" ""; json_close_object
		json_add_object "dhcp_leases"; json_close_object
		json_add_object "geodat_get"; json_close_object
		json_add_object "geodat_update"; json_close_object
		json_add_object "geodat_setcfg"
			json_add_string "enabled" ""; json_add_string "cron" ""
			json_add_string "cron_schedule" ""; json_add_string "source_url" ""
		json_close_object
		json_add_object "geodat_rollback"; json_close_object
		json_add_object "balancers_get"; json_close_object
		json_add_object "balancers_set"; json_add_array "balancers"; json_close_array; json_close_object
		json_add_object "enable_api"; json_close_object
		json_add_object "validate"; json_close_object
		json_add_object "config_get"; json_close_object
		json_add_object "config_test"; json_add_string "config" ""; json_close_object
		json_add_object "config_save"; json_add_string "config" ""; json_close_object
		json_add_object "update_check"; json_close_object
		json_add_object "update_apply"; json_close_object
		json_dump
	;;
	call)
		case "$2" in
			status)    get_status ;;
			stats)     get_stats ;;
			outbounds) get_outbounds ;;
			out_meta)  get_outmeta ;;
			probe_set) do_probe_set ;;
			reset)     do_reset ;;
			validate)  do_validate ;;
			config_get)
				cfg=$(config_file)
				json_init
				json_add_string path "$cfg"
				json_add_string config "$(cat "$cfg" 2>/dev/null)"
				json_dump
			;;
			config_test)
				input=$(cat)
				tmp=$(mktemp)
				printf '%s' "$input" | jsonfilter -e '@.config' > "$tmp" 2>/dev/null
				out=$($XRAY -test -format json -config "$tmp" 2>&1); rc=$?
				rm -f "$tmp"
				msg=$(printf '%s\n' "$out" | grep -viE '^Xray [0-9]|Penetrates Everything|unified platform|infra/conf/serial: Reading' | tr -s '\r\n\t ' ' ')
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "${msg:-no output}"
				json_dump
			;;
			config_save)
				input=$(cat)
				tmp=$(mktemp)
				printf '%s' "$input" | jsonfilter -e '@.config' > "$tmp" 2>/dev/null
				msg=$("$SUB" config-save "$tmp" 2>&1); rc=$?
				rm -f "$tmp"
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			sub_get)   "$SUB" status ;;
			sub_fetch) run_ok "$SUB" fetch ;;
			sub_apply) run_ok "$SUB" apply ;;
			sub_setcfg)
				input=$(cat)
				c=$(echo "$input"  | jsonfilter -e '@.cron' 2>/dev/null)
				s=$(echo "$input"  | jsonfilter -e '@.cron_schedule' 2>/dev/null)
				a=$(echo "$input"  | jsonfilter -e '@.auto_apply' 2>/dev/null)
				ug=$(echo "$input" | jsonfilter -e '@.user_agent' 2>/dev/null)
				msg=$("$SUB" set-cfg "$c" "$s" "$a" "$ug" 2>&1); rc=$?
				json_init; json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"; json_add_string msg "$msg"; json_dump
			;;
			sub_add)
				input=$(cat)
				p=$(echo "$input" | jsonfilter -e '@.prefix' 2>/dev/null)
				u=$(echo "$input" | jsonfilter -e '@.url' 2>/dev/null)
				msg=$("$SUB" sub-add "$p" "$u" 2>&1); rc=$?
				json_init; json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"; json_add_string msg "$msg"; json_dump
			;;
			sub_del)
				input=$(cat)
				id=$(echo "$input" | jsonfilter -e '@.id' 2>/dev/null)
				msg=$("$SUB" sub-del "$id" 2>&1); rc=$?
				json_init; json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"; json_add_string msg "$msg"; json_dump
			;;
			sub_edit)
				input=$(cat)
				id=$(echo "$input" | jsonfilter -e '@.id' 2>/dev/null)
				p=$(echo "$input"  | jsonfilter -e '@.prefix' 2>/dev/null)
				u=$(echo "$input"  | jsonfilter -e '@.url' 2>/dev/null)
				en=$(echo "$input" | jsonfilter -e '@.enabled' 2>/dev/null)
				msg=$("$SUB" sub-edit "$id" "$p" "$u" "$en" 2>&1); rc=$?
				json_init; json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"; json_add_string msg "$msg"; json_dump
			;;
			rules_get) "$RULES" get ;;
			list_entries)
				input=$(cat)
				name=$(echo "$input" | jsonfilter -e '@.name' 2>/dev/null)
				json_init
				if echo "$name" | grep -qE '^[A-Za-z0-9_-]{1,32}$'; then
					json_add_string name "$name"
					json_add_string entries "$(cat "$STATE/lists/$name.lst" 2>/dev/null)"
				else
					json_add_string name ""
					json_add_string entries ""
				fi
				json_dump
			;;
			lists_set|devices_set|georules_set)
				case "$2" in
					lists_set)    key='@.lists';   cmd=lists-set ;;
					devices_set)  key='@.devices'; cmd=devices-set ;;
					georules_set) key='@.rules';   cmd=georules-set ;;
				esac
				input=$(cat)
				f=$(mktemp)
				echo "$input" | jsonfilter -e "$key" > "$f" 2>/dev/null
				msg=$("$RULES" "$cmd" "$f" 2>&1); rc=$?
				rm -f "$f"
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			routing_set)
				input=$(cat)
				f=$(mktemp)
				json_init
				v=$(echo "$input" | jsonfilter -e '@.default_exit' 2>/dev/null);     [ -n "$v" ] && json_add_string default_exit "$v"
				v=$(echo "$input" | jsonfilter -e '@.registry_enabled' 2>/dev/null); [ -n "$v" ] && json_add_string registry_enabled "$v"
				v=$(echo "$input" | jsonfilter -e '@.registry_exit' 2>/dev/null);    [ -n "$v" ] && json_add_string registry_exit "$v"
				v=$(echo "$input" | jsonfilter -e '@.registry_geosite' 2>/dev/null); [ -n "$v" ] && json_add_string registry_geosite "$v"
				v=$(echo "$input" | jsonfilter -e '@.registry_geoip' 2>/dev/null);   [ -n "$v" ] && json_add_string registry_geoip "$v"
				v=$(echo "$input" | jsonfilter -e '@.tproxy_port' 2>/dev/null);      [ -n "$v" ] && json_add_string tproxy_port "$v"
				json_dump > "$f"
				msg=$("$RULES" globals-set "$f" 2>&1); rc=$?
				rm -f "$f"
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			rules_apply)
				msg=$("$RULES" apply 2>&1); rc=$?
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			fw_get) "$FW" status ;;
			fw_set)
				input=$(cat)
				en=$(echo "$input" | jsonfilter -e '@.enabled' 2>/dev/null)
				case "$en" in
					1|true)  msg=$("$FW" on 2>&1);  rc=$? ;;
					0|false) msg=$("$FW" off 2>&1); rc=$? ;;
					*) msg="invalid enabled value"; rc=1 ;;
				esac
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			dhcp_leases)
				json_init
				json_add_array leases
				if [ -f /tmp/dhcp.leases ]; then
					while read -r exp mac ip host rest; do
						[ -n "$ip" ] || continue
						json_add_object
						json_add_string ip "$ip"
						json_add_string mac "$mac"
						json_add_string host "${host:--}"
						json_close_object
					done < /tmp/dhcp.leases
				fi
				json_close_array
				json_dump
			;;
			geodat_get) "$GEODAT" status ;;
			geodat_update)
				# detached like update_apply: the download can take minutes
				setsid sh -c '/usr/share/xray-monitor/xray-geodat update > /tmp/xray-geodat.log 2>&1' >/dev/null 2>&1 &
				json_init
				json_add_boolean ok 1
				json_add_string msg "Update started; watch the status card."
				json_dump
			;;
			geodat_setcfg)
				input=$(cat)
				en=$(echo "$input"  | jsonfilter -e '@.enabled' 2>/dev/null)
				c=$(echo "$input"   | jsonfilter -e '@.cron' 2>/dev/null)
				s=$(echo "$input"   | jsonfilter -e '@.cron_schedule' 2>/dev/null)
				u=$(echo "$input"   | jsonfilter -e '@.source_url' 2>/dev/null)
				msg=$("$GEODAT" set-cfg "$en" "$c" "$s" "$u" 2>&1); rc=$?
				json_init; json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"; json_add_string msg "$msg"; json_dump
			;;
			geodat_rollback)
				msg=$("$GEODAT" rollback 2>&1); rc=$?
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			enable_api)
				msg=$("$SUB" enable-api 2>&1); rc=$?
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			update_check)
				installed=$(opkg status luci-app-xray-monitor 2>/dev/null | sed -n 's/^Version: //p' | head -n1)
				latest=$("$SUB" latest-version 2>/dev/null)
				json_init
				json_add_string installed "${installed:-unknown}"
				json_add_string latest "${latest:-}"
				json_add_boolean update_available "$([ -n "$latest" ] && [ "$latest" != "$installed" ] && echo 1 || echo 0)"
				json_dump
			;;
			update_apply)
				# detach so the rpcd restart during opkg install can't kill the update
				setsid sh -c 'sleep 2; /usr/share/xray-monitor/xray-sub self-update > /tmp/xraymon-update.log 2>&1' >/dev/null 2>&1 &
				json_init
				json_add_boolean ok 1
				json_add_string msg "Update started; the page will reconnect in a few seconds."
				json_dump
			;;
			balancers_get) "$SUB" balancers-get ;;
			balancers_set)
				input=$(cat)
				f=$(mktemp)
				echo "$input" | jsonfilter -e '@.balancers' > "$f" 2>/dev/null
				msg=$("$SUB" balancers-set "$f" 2>&1); rc=$?
				rm -f "$f"
				json_init
				json_add_boolean ok "$([ "$rc" -eq 0 ] && echo 1 || echo 0)"
				json_add_string msg "$msg"
				json_dump
			;;
			*)         printf '{}' ;;
		esac
	;;
esac
